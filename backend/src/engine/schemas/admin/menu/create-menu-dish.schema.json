{
    "id": "create_menu_dish",
    "name": "Crear Platillo",
    "description": "Agrega un nuevo platillo al menú, vinculado a una categoría existente.",
    "api": {
        "method": "POST",
        "path": "/menu/dishes",
        "tags": ["Admin / Menú"],
        "body": {
            "properties": {
                "dishCode": { "type": "string" },
                "categoryCode": { "type": "string" },
                "name": { "type": "string" },
                "description": { "type": "string" },
                "price": { "type": "number", "minimum": 0 },
                "imageUrl": { "type": "string" }
            },
            "required": ["dishCode", "categoryCode", "name", "price"]
        }
    },
    "startAt": "save_dish",
    "nodes": {
        "save_dish": {
            "type": "action",
            "handler": "saveDish",
            "next": "end",
            "onError": "end"
        }
    }
}
