{
    "id": "auth_pin",
    "name": "Login PIN (POS)",
    "description": "Autenticación con employee_number + PIN numérico para micrositios POS (meseros, caja, cocina). Devuelve JWT Bearer en body. El campo context es opcional y controla validaciones adicionales (ej: 'cashier' exige can_access_cashier).",
    "api": {
        "method": "POST",
        "path": "/auth/pin",
        "auth": "none",
        "body": {
            "required": [
                "employeeNumber",
                "pinCode"
            ],
            "properties": {
                "employeeNumber": {
                    "type": "string",
                    "example": "MES001"
                },
                "pinCode": {
                    "type": "string",
                    "example": "1234"
                },
                "context": {
                    "type": "string",
                    "example": "waiter",
                    "description": "Contexto del login: 'waiter', 'cashier', 'kitchen'. Controla validaciones adicionales."
                }
            }
        }
    },
    "startAt": "do_pin",
    "nodes": {
        "do_pin": {
            "type": "action",
            "handler": "validatePin",
            "next": "end_success",
            "onError": "end"
        },
        "end_success": {
            "type": "end",
            "response": {
                "status": 200,
                "body": {
                    "token": "{{state.data.token}}",
                    "employeeNumber": "{{state.data.employeeNumber}}",
                    "firstName": "{{state.data.firstName}}",
                    "lastName": "{{state.data.lastName}}",
                    "areaCode": "{{state.data.areaCode}}",
                    "canAccessCashier": "{{state.data.canAccessCashier}}"
                }
            }
        }
    }
}