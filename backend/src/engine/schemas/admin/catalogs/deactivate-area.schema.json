    "api": {
        "method": "DELETE",
        "path": "/employees/areas/:code",
        "tags": ["Admin / Catalogos"]
    },
    "startAt": "deactivate_area_node",
    "nodes": {
        "deactivate_area_node": {
            "type": "action",
            "handler": "deactivateArea",
            "next": "end",
            "onError": "end"
        }
    }
}
