{
    "id": "update_area",
    "name": "Update Area",
    "description": "Actualiza el nombre, estado activo y permiso de acceso a caja de un área existente.",
    "api": {
        "method": "PUT",
        "path": "/employees/areas/:code",
        "tags": [
            "Admin / Catalogos"
        ],
        "body": {
            "properties": {
                "areaName": {
                    "type": "string",
                    "example": "Cocina"
                },
                "isActive": {
                    "type": "boolean",
                    "example": true
                },
                "canAccessCashier": {
                    "type": "boolean",
                    "example": false
                }
            },
            "required": [
                "areaName"
            ]
        }
    },
    "startAt": "update_area_node",
    "nodes": {
        "update_area_node": {
            "type": "action",
            "handler": "updateArea",
            "next": "end",
            "onError": "end"
        }
    }
}